# ─── Nexus Playground – environment variables ────────────────────────────────
# Copy to .env and fill in the values from your nexus-staging environment.

# Where to fire webhooks (nexus-staging base URL)
NEXUS_STAGING_BASE_URL=http://localhost:3000

# Webhook secrets — copy the values from nexus-staging's environment variables
ORANGE_HEALTH_WEBHOOK_SECRET_KEY=
HEALTHIANS_WEBHOOK_SECRET_KEY=
REDCLIFFE_WEBHOOK_SECRET_KEY=
# Note: nexus has a typo (SERCRET) – the *value* must match what staging uses
EKIN_CARE_WEBHOOK_SECRET_KEY=

# Razorpay – copy RAZORPAY_WEBHOOK_SECRET from nexus-staging's environment
RAZORPAY_WEBHOOK_SECRET=

# Server port (optional, defaults to 3001)
PORT=3001
